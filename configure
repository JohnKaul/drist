#!/bin/sh

#: configure
# This simple script will set options in the makefile.

prefix='\/usr\/local\/bin'
mandir='\/usr\/local\/share\/man\/man1'
for arg in "$@"; do
    case "$arg" in
    --mandir=*)
        mandir=`echo $arg | sed 's/--mandir=//'`
        ;;
    --prefix=*)
        prefix=`echo $arg | sed 's/--prefix=//'`
        ;;
--help | -h )
        echo 'usage: ./configure [options]'
        echo 'options:'
        echo '  --prefix=<path>: installation prefix (default /usr/local/bin)'
        echo '  --mandir=<path>: installation prefix (default /usr/local/share/man/man1)'
        echo 'all invalid options are silently ignored'
        exit 0
        ;;
    esac
done
sed -i '' "s,^PREFIX.*,PREFIX		:=	$prefix,g" makefile
sed -i '' "s,^MANDIR.*,MANDIR	        :=	$mandir,g" Makefile
echo 'configuration complete, type `make` to build.'
